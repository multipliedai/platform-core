{
  "name": "@multipliedai/platform-core",
  "version": "1.0.17",
  "tag": "v1.0.17",
  "private": true,
  "description": "Core shared packages for web, mobile, and backend services.",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./packages/common": {
      "types": "./dist/packages/common/src/index.d.ts",
      "default": "./dist/packages/common/src/index.js"
    },
    "./packages/common/*": {
      "types": "./dist/packages/common/src/*.d.ts",
      "default": "./dist/packages/common/src/*.js"
    },
    "./packages/mobileapp": {
      "types": "./dist/packages/mobileapp/src/index.d.ts",
      "default": "./dist/packages/mobileapp/src/index.js"
    },
    "./packages/mobileapp/*": {
      "types": "./dist/packages/mobileapp/src/*.d.ts",
      "default": "./dist/packages/mobileapp/src/*.js"
    },
    "./packages/webapp": {
      "types": "./packages/webapp/src/index.ts",
      "default": "./packages/webapp/src/index.ts"
    },
    "./packages/webapp/*": {
      "types": "./packages/webapp/src/*.ts",
      "default": "./packages/webapp/src/*.ts"
    }
  },
  "files": [
    "dist/**",
    "packages/**",
    "src/**",
    "tsconfig.build.json"
  ],
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "graphql": "^16.8.1",
    "lodash": "^4.17.23",
    "luxon": "^3.7.2",
    "moment": "^2.30.1",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "release:patch": "node -e \"const fs=require('fs');const {execSync}=require('child_process');const pkgPath='./package.json';const pkg=JSON.parse(fs.readFileSync(pkgPath,'utf8'));const [maj,min,pat]=String(pkg.version).split('.').map(Number);const next=`${maj}.${min}.${pat+1}`;pkg.version=next;pkg.tag=`v${next}`;fs.writeFileSync(pkgPath, JSON.stringify(pkg,null,2)+'\\n');execSync(`git tag v${next}`,{stdio:'inherit'});execSync(`git push origin v${next}`,{stdio:'inherit'});\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.2"
  }
}
